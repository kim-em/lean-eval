+def queryExecutableLocation (cmd : String) : IO System.FilePath := do
+  let out ← IO.Process.run {
+    cmd := "which",
+    args := #[cmd],
+    stdout := .piped,
+  }
+  return out.trimAscii.toString
+
+def queryDynamicLoader? (binary : System.FilePath) : IO (Option System.FilePath) := do
+  let out ← IO.Process.output {
+    cmd := "ldd",
+    args := #[binary.toString],
+  }
+  if out.exitCode != 0 then
+    return none
+  let matchesLoader (token : String) : Bool :=
+    token.contains "ld-linux" || token.contains "ld-musl"
+  let rec go : List String → Option System.FilePath
+    | [] => none
+    | line :: rest =>
+        let trimmed := line.trimAscii.toString
+        if trimmed.startsWith "/" then
+          let token := trimmed.takeWhile (fun c => !c.isWhitespace) |>.toString
+          if matchesLoader token then
+            some <| System.FilePath.mk token
+          else
+            go rest
+        else
+          go rest
+  return go (out.stdout.splitOn "\n")
+
+def withDynamicLoaderPaths (cmd : System.FilePath) (paths : Array System.FilePath) :
+    IO (Array System.FilePath) := do
+  match ← queryDynamicLoader? cmd with
+  | some loader => return paths.push loader
+  | none => return paths
+
